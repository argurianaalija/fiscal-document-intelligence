# Fiscal Document Intelligence Service — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Service settings ──────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
VERSION=1.0.0

# ── Extraction ────────────────────────────────────────────────────────────────
AI_MODEL=claude-sonnet-4-6
CONFIDENCE_THRESHOLD=0.75
MAX_FILE_SIZE_MB=20

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for this service
API_KEYS=dev-key-change-me,another-key

# ── Infrastructure (for production) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://fiscal:fiscal@localhost:5432/fiscal_docs
